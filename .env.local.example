# Supabase project credentials — needed for the public leaderboard.
# Without these, the game still runs but scores stay on the local device.
#
# Find these in Supabase → Project Settings → API.
# The anon key is safe to expose in the client — RLS policies protect data.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...your-anon-key...

# Optional: subpath used when deploying to https://<user>.github.io/<repo>/
# Leave unset for custom-domain (root-path) deployments.
# BASE_PATH=/hand-tetris
